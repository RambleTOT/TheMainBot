# ====== PRODUCTION .env (заполнить на сервере, НЕ коммитить) ======
# Скопировать в /opt/themain/.env и заполнить.

# Токен бота от @BotFather
BOT_TOKEN=

# PostgreSQL (пароль задаётся при деплое, см. deploy.sh DB_PASS)
DATABASE_URL=postgresql+asyncpg://themain:CHANGE_DB_PASSWORD@localhost:5432/themain

# Боевой режим: тестовая кнопка оплаты отключена
TEST_MODE=false

# --- Админка ---
ADMIN_PASSWORD=          # надёжный пароль для входа в админку
ADMIN_SECRET=            # python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECURE_COOKIES=true   # админка за HTTPS
# Путь админки (по умолчанию /admin → https://домен/admin). Обычно менять не нужно.
# ADMIN_BASE_PATH=/admin

ADMIN_IDS=

# --- Ресурсы (канал/форум/чат): ссылки и ID; бот — админ с правами приглашать/банить ---
RES_PRIVATKA_URL=
RES_FORUM_URL=
RES_CHAT_URL=
RES_PRIVATKA_CHAT_ID=
RES_FORUM_CHAT_ID=
RES_CHAT_CHAT_ID=
