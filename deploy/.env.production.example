# ====== PRODUCTION .env ======
# Скопировать в /opt/themain/.env и заполнить.
#
# ВАЖНО: значения задаются на сервере через systemd (EnvironmentFile), поэтому
# НЕ добавляйте комментарии в КОНЦЕ строк со значениями — systemd затащит их
# в значение. Комментарии — только на отдельной строке (как здесь).

# Токен бота от @BotFather
BOT_TOKEN=

# PostgreSQL (пароль совпадает с DB_PASS в deploy.sh)
DATABASE_URL=postgresql+asyncpg://themain:CHANGE_DB_PASSWORD@localhost:5432/themain

# Боевой режим (тестовая кнопка оплаты отключена)
TEST_MODE=false

# --- Админка ---
# Пароль входа (≥ 8 символов). Со спецсимволами — в одинарных кавычках.
ADMIN_PASSWORD=
# Секрет cookie-сессии: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=
# Cookie только по HTTPS (на проде — true)
ADMIN_SECURE_COOKIES=true
# Путь админки (по умолчанию /admin). Обычно менять не нужно:
# ADMIN_BASE_PATH=/admin
# Ограничить вход в админку по IP (через запятую). Пусто = доступ по паролю с любого IP.
# Свой IP: на своём компьютере открой https://2ip.ru
# ADMIN_ALLOW_IPS=203.0.113.10

ADMIN_IDS=

# --- Ресурсы (канал/форум/чат): ссылки и ID ---
# Бот должен быть админом ресурса с правами «приглашать» и «банить».
RES_PRIVATKA_URL=
RES_FORUM_URL=
RES_CHAT_URL=
RES_PRIVATKA_CHAT_ID=
RES_FORUM_CHAT_ID=
RES_CHAT_CHAT_ID=
