# ===== ОБЯЗАТЕЛЬНО =====
# Токен бота от @BotFather
BOT_TOKEN=

# ===== БАЗА ДАННЫХ =====
# По умолчанию — локальный SQLite (для разработки/демо).
# Для production используйте PostgreSQL, например:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/themain
DATABASE_URL=sqlite+aiosqlite:///bot.db

# ===== РЕЖИМ =====
# true  — демо: появляется кнопка «✅ Я оплатил (тест)» (реальной оплаты нет)
# false — боевой режим (тестовая кнопка отключена, нужен реальный платёжный провайдер)
TEST_MODE=true

# Telegram ID администраторов через запятую (для команды /id)
ADMIN_IDS=

# ===== ВЕБ-АДМИНКА =====
# Пароль для входа в админ-панель (обязателен для запуска админки)
ADMIN_PASSWORD=
# Секрет для подписи cookie-сессии админки — ОБЯЗАТЕЛЕН, минимум 16 случайных символов.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=
# На боевом сервере (админка за HTTPS) выставьте true — cookie только по HTTPS.
# Локально (http://127.0.0.1) оставьте false, иначе не залогиниться.
ADMIN_SECURE_COOKIES=false

# ===== РЕСУРСЫ (приватка/форум/чат) =====
# Публичные ссылки-приглашения (показываются как кнопки). Заполнит заказчик.
RES_PRIVATKA_URL=
RES_FORUM_URL=
RES_CHAT_URL=

# ID каналов/групп для автоматической выдачи и отзыва доступа.
# Если указать — бот создаёт ссылки с заявкой на вступление и кикает по окончании подписки.
# Бот должен быть АДМИНИСТРАТОРОМ в этих ресурсах с правами «приглашать» и «банить».
# Узнать ID: добавьте бота в группу/канал и отправьте там команду /id
RES_PRIVATKA_CHAT_ID=
RES_FORUM_CHAT_ID=
RES_CHAT_CHAT_ID=

# Примечание: тексты, картинку приветствия, цены и оферту теперь можно менять
# в веб-админке (раздел «Тексты» и «Тарифы и цены») — вносить в .env их не нужно.
